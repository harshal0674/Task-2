generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model User {
  id        String     @id @default(cuid())
  email     String     @unique
  password  String
  name      String?
  progress  Progress[]
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
}

model Progress {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  step      String
  data      String   // Storing JSON string of the state
  createdAt DateTime @default(now())
}
